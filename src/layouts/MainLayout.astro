---
// src/layouts/MainLayout.astro
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<html lang="es" data-theme="rampmaster">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Rampmaster SpA</title>
    <link rel="icon" type="image/png" href="/logo_black.png" />
    <link rel="manifest" href="/manifest.json">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,300;0,400;0,700;0,900;1,300;1,400;1,700;1,900&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
    <style is:global>
        body { font-family: 'Open Sans', sans-serif; font-size: 14.67px; }
        h1, h2, h3, h4, h5, h6, .font-heading { font-family: 'Lato', sans-serif; }

        /* Logo Toggle Logic */
        .logo-dark { display: none; }
        .logo-light { display: block; }

        [data-theme="rampmaster-dark"] .logo-dark { display: block; }
        [data-theme="rampmaster-dark"] .logo-light { display: none; }
    </style>
    <script is:inline>
        // Theme Toggle Logic
        if (localStorage.getItem("theme") === null) {
            document.documentElement.setAttribute("data-theme", "rampmaster");
        } else {
            document.documentElement.setAttribute("data-theme", localStorage.getItem("theme"));
        }
    </script>
</head>
<body class="bg-base-100 text-base-content transition-colors duration-300 min-h-screen flex flex-col">

    <!-- Navbar -->
    <header class="fixed top-0 z-50 w-full bg-base-100/95 backdrop-blur-sm border-b border-base-200 transition-colors duration-300">
        <div class="navbar container mx-auto px-4 min-h-[4rem]">
            <!-- Logo Area -->
            <div class="flex-1">
                <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity py-1">
                    <div class="w-10 h-10 md:w-12 md:h-12 relative flex-shrink-0">
                        <img src="/logo_black.png" alt="Logo Rampmaster" class="logo-light w-full h-full object-contain" />
                        <img src="/logo_white.png" alt="Logo Rampmaster" class="logo-dark w-full h-full object-contain" />
                    </div>
                    <div class="flex flex-col leading-tight">
                        <span class="font-heading font-black text-lg md:text-xl">Rampmaster SpA</span>
                        <span class="text-[9px] md:text-[10px] font-heading font-bold uppercase tracking-wider opacity-60 hidden sm:block">Tu plataforma para llegar al próximo nivel</span>
                    </div>
                </a>
            </div>

            <!-- Desktop Menu & Actions -->
            <div class="flex-none gap-2">
                <!-- Desktop Links -->
                <ul class="menu menu-horizontal px-1 font-semibold opacity-80 hidden md:flex">
                    <li><a href="/#servicios" class="hover:bg-base-200 rounded-md">Servicios</a></li>
                    <li><a href="/#nosotros" class="hover:bg-base-200 rounded-md">Nosotros</a></li>
                </ul>

                <!-- Theme Toggle -->
                <label class="swap swap-rotate btn btn-ghost btn-circle btn-sm">
                    <input type="checkbox" id="theme-toggle" />
                    <svg class="swap-on fill-current w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"/></svg>
                    <svg class="swap-off fill-current w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"/></svg>
                </label>

                <!-- Contact Button (Desktop) -->
                <a href="/#contacto" class="btn btn-primary btn-sm text-white font-bold rounded-full px-6 hidden md:flex">Contáctanos</a>

                <!-- Mobile Menu Dropdown -->
                <div class="dropdown dropdown-end md:hidden">
                    <label tabindex="0" class="btn btn-ghost btn-circle btn-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
                    </label>
                    <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52 border border-base-200">
                        <li><a href="/#servicios">Servicios</a></li>
                        <li><a href="/#nosotros">Nosotros</a></li>
                        <li><a href="/#contacto" class="text-primary font-bold">Contáctanos</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-grow">
        <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-neutral text-neutral-content py-12 border-t border-base-300/10">
        <div class="container mx-auto px-4">
            <div class="flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 relative opacity-80 grayscale hover:grayscale-0 transition-all">
                        <img src="/logo_white.png" alt="Logo Rampmaster" class="logo-light w-full h-full object-contain" />
                        <img src="/logo_black.png" alt="Logo Rampmaster" class="logo-dark w-full h-full object-contain" />
                    </div>
                    <span class="font-heading font-bold text-lg">Rampmaster SpA</span>
                </div>
                <div class="text-sm opacity-70">
                    &copy; 2024 Rampmaster SpA. Todos los derechos reservados.
                </div>
                <div class="flex gap-6 opacity-70">
                    <a href="/privacidad" class="hover:bg-white/10 rounded-md px-3 py-1 transition-colors">Privacidad</a>
                    <a href="/terminos" class="hover:bg-white/10 rounded-md px-3 py-1 transition-colors">Términos</a>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // Theme Toggle Functionality
        const themeToggle = document.getElementById('theme-toggle') as HTMLInputElement;
        const html = document.documentElement;
        
        if (localStorage.getItem("theme") === "rampmaster-dark") {
            if (themeToggle) themeToggle.checked = true;
        }

        themeToggle?.addEventListener('change', function() {
            if (this.checked) {
                html.setAttribute('data-theme', 'rampmaster-dark');
                localStorage.setItem('theme', 'rampmaster-dark');
            } else {
                html.setAttribute('data-theme', 'rampmaster');
                localStorage.setItem('theme', 'rampmaster');
            }
        });
    </script>
</body>
</html>
