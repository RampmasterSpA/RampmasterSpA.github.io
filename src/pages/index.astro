---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Software Factory">
    <!-- Hero Section -->
    <div class="hero min-h-screen bg-rm-black text-white relative overflow-hidden pt-20">
        <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-rm-turquoise/20 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 animate-pulse"></div>
        <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-rm-yellow/10 rounded-full blur-[100px] translate-y-1/3 -translate-x-1/4 animate-pulse" style="animation-delay: 2s;"></div>

        <div class="hero-content text-center relative z-10 px-4">
            <div class="max-w-4xl">
                <div class="inline-block mb-6 px-4 py-1.5 border border-primary/50 rounded-full text-primary text-sm font-bold tracking-wider uppercase bg-primary/10 backdrop-blur-sm">
                    Software Factory
                </div>
                <h1 class="text-5xl md:text-7xl font-heading font-black mb-8 leading-tight">
                    Tu plataforma para llegar al <span class="text-primary">próximo nivel</span>
                </h1>
                <p class="py-6 text-xl md:text-2xl text-gray-300 max-w-2xl mx-auto font-light">
                    Impulsamos tu negocio con soluciones tecnológicas a medida, escalables y de alto rendimiento.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
                    <a href="#contacto" class="btn btn-primary btn-lg text-primary-content font-bold border-none hover:brightness-110 px-8 shadow-lg shadow-primary/20">
                        Cotiza tu Proyecto
                    </a>
                    <a href="#servicios" class="btn btn-outline btn-lg text-white hover:bg-white/10 hover:text-white px-8">
                        Nuestras Soluciones
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Services Section -->
    <section id="servicios" class="py-24 bg-base-200 transition-colors duration-300">
        <div class="container mx-auto px-4">
            <div class="text-center mb-20">
                <h2 class="text-4xl md:text-5xl font-heading font-bold mb-4">Nuestras Soluciones</h2>
                <div class="w-24 h-1.5 bg-primary mx-auto rounded-full"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 border-t-4 border-secondary group hover:-translate-y-2">
                    <div class="card-body items-center text-center p-8">
                        <div class="w-20 h-20 rounded-full bg-secondary/10 flex items-center justify-center mb-6 group-hover:bg-secondary group-hover:text-white transition-colors duration-300 text-secondary">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                        </div>
                        <h3 class="card-title text-2xl font-heading font-bold mb-3">Desarrollo Móvil</h3>
                        <p class="opacity-70 leading-relaxed">Aplicaciones nativas para Android e iOS, y soluciones multiplataforma con Flutter y React Native.</p>
                    </div>
                </div>

                <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 border-t-4 border-primary group hover:-translate-y-2">
                    <div class="card-body items-center text-center p-8">
                        <div class="w-20 h-20 rounded-full bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-primary-content transition-colors duration-300 text-primary">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                        </div>
                        <h3 class="card-title text-2xl font-heading font-bold mb-3">Desarrollo Web</h3>
                        <p class="opacity-70 leading-relaxed">Plataformas web modernas, SPAs, y sistemas de gestión empresarial robustos y seguros.</p>
                    </div>
                </div>

                <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 border-t-4 border-accent group hover:-translate-y-2">
                    <div class="card-body items-center text-center p-8">
                        <div class="w-20 h-20 rounded-full bg-accent/10 flex items-center justify-center mb-6 group-hover:bg-accent group-hover:text-white transition-colors duration-300 text-accent">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>
                        </div>
                        <h3 class="card-title text-2xl font-heading font-bold mb-3">Cloud & DevOps</h3>
                        <p class="opacity-70 leading-relaxed">Arquitectura en la nube (AWS, Google Cloud), CI/CD y optimización de infraestructura.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contacto" class="py-24 bg-base-100 relative overflow-hidden transition-colors duration-300">
        <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(currentColor 1px, transparent 1px); background-size: 30px 30px;"></div>
        <div class="container mx-auto px-4 relative z-10">
            <div class="max-w-4xl mx-auto bg-base-200/50 backdrop-blur-lg rounded-3xl p-8 md:p-16 border border-base-300 text-center shadow-2xl">
                <h2 class="text-4xl md:text-5xl font-heading font-bold mb-6">¿Tienes un desafío para nosotros?</h2>
                <p class="text-xl opacity-80 mb-10">Estamos listos para llevar tu idea al siguiente nivel.</p>
                <a href="mailto:rmorenp@rampmaster.org" class="btn btn-primary btn-lg text-primary-content font-bold rounded-full px-8 py-4 hover:brightness-110 transition-transform hover:scale-105 shadow-lg shadow-primary/20">
                    rmorenp@rampmaster.org
                </a>
            </div>
        </div>
    </section>
</MainLayout>
