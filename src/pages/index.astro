---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Suscripciones de Ingeniería de Software">
    <!-- Hero Section -->
    <div class="hero min-h-screen bg-rm-black text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-rm-teal/20 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 animate-pulse"></div>
        <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-rm-yellow/10 rounded-full blur-[100px] translate-y-1/3 -translate-x-1/4 animate-pulse" style="animation-delay: 2s;"></div>

        <div class="hero-content text-center relative z-10 px-4 pt-10 pb-20">
            <div class="max-w-4xl">
                <div class="inline-block mb-6 px-4 py-1.5 border border-primary/50 rounded-full text-primary text-sm font-bold tracking-wider uppercase bg-primary/10 backdrop-blur-sm">
                    Tecnología con Sentido Humano
                </div>
                <h1 class="text-5xl md:text-7xl font-heading font-black mb-8 leading-tight">
                    No buscamos vender tecnología, buscamos <span class="text-rm-yellow">solucionar los problemas de tu vida</span>
                </h1>
                <p class="py-6 text-xl md:text-2xl text-gray-300 max-w-2xl mx-auto font-light">
                    Transformamos la complejidad técnica en soluciones cotidianas, escalables y de alto impacto para tu negocio y tu día a día.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
                    <a href="#contacto" class="btn btn-primary btn-lg text-white font-bold border-none hover:brightness-110 px-8 shadow-lg shadow-primary/20">
                        Cuéntanos tu problema
                    </a>
                    <a href="#servicios" class="btn btn-outline btn-lg text-white hover:bg-white/10 hover:text-white px-8">
                        Nuestras Soluciones
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Social Proof Section -->
    <section class="py-16 bg-base-100 border-b border-base-200">
        <div class="container mx-auto px-4">
            <!-- Clientes Directos -->
            <div class="mb-12 text-center">
                <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-8">Empresas que confían en Rampmaster</h3>
                <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
                    <img class="h-12 rounded flex items-center justify-center text-xs"
                         src="/images/clients/obispadosb.png" alt="Obispado de San Bernardo"
                    />
                    <img class="h-12 rounded flex items-center justify-center text-xs"
                         src="/images/clients/automotorabilbao.png" alt="Automotora Bilbao"
                    />
                    <img class="h-12 rounded flex items-center justify-center text-xs"
                         src="/images/clients/asech.png" alt="ASECH - Asociación de Emprendedores de Chile"
                    />
                    <img class="h-12 rounded flex items-center justify-center text-xs"
                         src="/images/clients/ortopodiamassalud.png" alt="Ortopedia Mas Salud"
                    />
                </div>
            </div>

            <!-- Experiencia del Equipo -->
            <div class="text-center pt-8 border-t border-base-200">
                <h3 class="text-xs font-bold text-rm-teal uppercase tracking-widest mb-6">Experiencia acumulada de nuestros colaboradores en proyectos para</h3>
                <div class="flex flex-wrap justify-center items-center gap-6 md:gap-12 opacity-50 grayscale hover:grayscale-0 ">
                    <img class="h-8 rounded flex items-center justify-center text-[10px]"
                        src="/images/collab/bithost.png" alt="Bithost"
                    />
                    <img class="h-8 rounded flex items-center justify-center text-[10px]"
                        src="/images/collab/ompchile.png" alt="Obras Misionales Pontificias de Chile"
                    />
                    <img class="h-8 rounded flex items-center justify-center text-[10px]"
                         src="/images/collab/dtschile.png" alt="DTS Chile"
                    />
                    <img class="h-8 rounded flex items-center justify-center text-[10px]"
                         src="/images/collab/fidelizador.png" alt="Fidelizador.com"
                    />
                    <img class="h-8 rounded flex items-center justify-center text-[10px]"
                         src="/images/collab/cem.png" alt="Conferencia del Episcopado Mexicano"
                    />
                    <img class="h-8 rounded flex items-center justify-center text-[10px]"
                         src="/images/collab/pegasus.jpg" alt="The Pegasus Company Group"
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section id="planes" class="py-24 bg-base-200 transition-colors duration-300">
        <div class="container mx-auto px-4">
            <div class="text-center mb-20">
                <h2 class="text-4xl md:text-5xl font-heading font-bold mb-4">Planes de Suscripción</h2>
                <p class="text-lg opacity-70 max-w-2xl mx-auto">Elige el nivel de soporte y desarrollo que tu negocio necesita hoy. Escala mañana.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
                <!-- Plan Continuidad -->
                <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 border border-base-300 hover:-translate-y-2">
                    <div class="card-body p-8">
                        <h3 class="text-2xl font-heading font-bold mb-2">Continuidad</h3>
                        <div class="text-4xl font-black mb-6">$175.000 <span class="text-sm font-normal opacity-60">+ IVA /mes</span></div>
                        <p class="opacity-70 mb-6 text-sm">Ideal para mantenimiento y pequeñas mejoras continuas.</p>
                        <ul class="space-y-3 mb-8 text-sm">
                            <li class="flex items-center gap-2"><svg class="w-5 h-5 text-rm-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> 5 Horas de desarrollo</li>
                            <li class="flex items-center gap-2"><svg class="w-5 h-5 text-rm-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Soporte Base</li>
                            <li class="flex items-center gap-2"><svg class="w-5 h-5 text-rm-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Reportes Mensuales</li>
                        </ul>
                        <a href="mailto:rmorenp@rampmaster.org?subject=Plan Continuidad" class="btn btn-outline btn-block">Seleccionar</a>
                    </div>
                </div>

                <!-- Plan Optimización (Destacado) -->
                <div class="card bg-base-100 shadow-2xl hover:shadow-3xl transition-all duration-300 border-t-4 border-rm-teal relative transform md:-translate-y-4 z-10">
                    <div class="absolute top-0 right-0 bg-rm-teal text-white text-xs font-bold px-3 py-1 rounded-bl-lg uppercase">Recomendado</div>
                    <div class="card-body p-8">
                        <h3 class="text-2xl font-heading font-bold mb-2 text-rm-teal">Optimización</h3>
                        <div class="text-4xl font-black mb-6">$384.000 <span class="text-sm font-normal opacity-60">+ IVA /mes</span></div>
                        <p class="opacity-70 mb-6 text-sm">Para negocios en crecimiento que requieren agilidad.</p>
                        <ul class="space-y-3 mb-8 text-sm">
                            <li class="flex items-center gap-2"><svg class="w-5 h-5 text-rm-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>12 Horas</strong> de desarrollo</li>
                            <li class="flex items-center gap-2"><svg class="w-5 h-5 text-rm-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Soporte Prioritario</li>
                            <li class="flex items-center gap-2"><svg class="w-5 h-5 text-rm-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Asesoría Técnica</li>
                        </ul>
                        <a href="mailto:rmorenp@rampmaster.org?subject=Plan Optimización" class="btn btn-primary btn-block text-white shadow-lg shadow-rm-teal/20">Empezar Ahora</a>
                    </div>
                </div>

                <!-- Plan Innovación -->
                <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 border border-base-300 hover:-translate-y-2">
                    <div class="card-body p-8">
                        <h3 class="text-2xl font-heading font-bold mb-2">Innovación</h3>
                        <div class="text-4xl font-black mb-6">$700.000 <span class="text-sm font-normal opacity-60">+ IVA /mes</span></div>
                        <p class="opacity-70 mb-6 text-sm">Desarrollo intensivo y transformación digital completa.</p>
                        <ul class="space-y-3 mb-8 text-sm">
                            <li class="flex items-center gap-2"><svg class="w-5 h-5 text-rm-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> <strong>25 Horas</strong> de desarrollo</li>
                            <li class="flex items-center gap-2"><svg class="w-5 h-5 text-rm-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Consultoría Estratégica</li>
                            <li class="flex items-center gap-2"><svg class="w-5 h-5 text-rm-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Arquitectura Cloud</li>
                        </ul>
                        <a href="mailto:rmorenp@rampmaster.org?subject=Plan Innovación" class="btn btn-outline btn-block">Seleccionar</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Scalability Section -->
    <section id="escalabilidad" class="py-24 bg-base-100 relative overflow-hidden">
        <div class="container mx-auto px-4">
            <div class="flex flex-col md:flex-row items-center gap-12">
                <div class="flex-1">
                    <div class="inline-block mb-4 px-3 py-1 bg-rm-yellow/10 text-rm-yellow rounded-full text-xs font-bold uppercase tracking-wide">Flexibilidad Total</div>
                    <h2 class="text-4xl font-heading font-bold mb-6">Escalabilidad Flexible</h2>
                    <p class="text-lg opacity-80 mb-6 leading-relaxed">
                        Entendemos que las necesidades de tu negocio fluctúan. Nuestro modelo se adapta a ti mes a mes.
                    </p>
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-full bg-base-200 flex items-center justify-center flex-shrink-0 font-bold text-xl">1</div>
                            <div>
                                <h4 class="font-bold text-lg mb-1">Horas Extra Estándar</h4>
                                <p class="opacity-70 text-sm">Si necesitas más horas, pagas la tarifa estándar hasta alcanzar el umbral del siguiente plan.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-full bg-base-200 flex items-center justify-center flex-shrink-0 font-bold text-xl">2</div>
                            <div>
                                <h4 class="font-bold text-lg mb-1">Incentivo al Upgrade</h4>
                                <p class="opacity-70 text-sm">Al superar el límite, aplicamos una tarifa ajustada para invitarte a mejorar tu plan y obtener más beneficios por menos costo unitario.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="flex-1 bg-base-200 rounded-3xl p-8 md:p-12 relative">
                    <!-- Abstract visual representation of scaling -->
                    <div class="absolute top-0 right-0 w-32 h-32 bg-rm-teal/10 rounded-full blur-3xl"></div>
                    <div class="absolute bottom-0 left-0 w-32 h-32 bg-rm-yellow/10 rounded-full blur-3xl"></div>
                    
                    <div class="relative z-10 space-y-4">
                        <div class="bg-base-100 p-4 rounded-xl shadow-sm flex justify-between items-center">
                            <span class="font-bold">Plan Actual</span>
                            <span class="badge badge-ghost">Continuidad</span>
                        </div>
                        <div class="flex justify-center py-2">
                            <svg class="w-6 h-6 opacity-30 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
                        </div>
                        <div class="bg-base-100 p-4 rounded-xl shadow-md border-l-4 border-rm-teal flex justify-between items-center transform scale-105">
                            <div>
                                <span class="font-bold block">Upgrade Automático</span>
                                <span class="text-xs opacity-60">Mejor costo/hora</span>
                            </div>
                            <span class="badge badge-primary text-white">Optimización</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Custom Development Section -->
    <section class="py-24 bg-rm-black text-white relative overflow-hidden">
        <!-- Background Pattern -->
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#444 1px, transparent 1px); background-size: 30px 30px;"></div>
        
        <div class="container mx-auto px-4 relative z-10">
            <div class="flex flex-col md:flex-row items-center gap-12 max-w-6xl mx-auto">
                <div class="flex-1 text-left">
                    <div class="inline-block mb-4 px-3 py-1 border border-rm-teal text-rm-teal rounded-full text-xs font-bold uppercase tracking-wide">Enterprise</div>
                    <h2 class="text-4xl md:text-5xl font-heading font-bold mb-6">Desarrollo a Medida</h2>
                    <p class="text-xl text-gray-400 mb-8 leading-relaxed">
                        ¿Tu proyecto no encaja en una suscripción? Diseñamos y construimos soluciones de software complejas desde cero, adaptadas 100% a tus reglas de negocio.
                    </p>
                    <ul class="space-y-4 mb-10">
                        <li class="flex items-center gap-3">
                            <span class="w-8 h-8 rounded-full bg-rm-teal/20 flex items-center justify-center text-rm-teal">✓</span>
                            <span>Arquitectura de Microservicios y Cloud Native</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <span class="w-8 h-8 rounded-full bg-rm-teal/20 flex items-center justify-center text-rm-teal">✓</span>
                            <span>Integraciones complejas (APIs, ERPs, Legacy)</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <span class="w-8 h-8 rounded-full bg-rm-teal/20 flex items-center justify-center text-rm-teal">✓</span>
                            <span>Desarrollo de Productos Digitales (MVP a Escala)</span>
                        </li>
                    </ul>
                    <a href="mailto:rmorenp@rampmaster.org?subject=Cotización Proyecto a Medida" class="btn btn-outline text-white border-white hover:bg-white hover:text-rm-black hover:border-white px-8">
                        Cotizar Proyecto Especial
                    </a>
                </div>
                <div class="flex-1 w-full">
                    <div class="relative bg-gradient-to-br from-gray-800 to-black p-1 rounded-2xl shadow-2xl transform rotate-1 hover:rotate-0 transition-transform duration-500">
                        <div class="bg-gray-900 rounded-xl p-8 h-full border border-gray-700">
                            <div class="flex items-center gap-4 mb-6 border-b border-gray-700 pb-4">
                                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                                <div class="text-xs text-gray-500 font-mono ml-auto">project_config.json</div>
                            </div>
                            <div class="space-y-3 font-mono text-sm">
                                <div class="flex gap-2">
                                    <span class="text-purple-400">const</span>
                                    <span class="text-blue-400">project</span>
                                    <span class="text-white">=</span>
                                    <span class="text-yellow-300">{'{'}</span>
                                </div>
                                <div class="pl-4 flex gap-2">
                                    <span class="text-red-400">type:</span>
                                    <span class="text-green-400">'Custom Solution'</span>,
                                </div>
                                <div class="pl-4 flex gap-2">
                                    <span class="text-red-400">scalability:</span>
                                    <span class="text-purple-400">true</span>,
                                </div>
                                <div class="pl-4 flex gap-2">
                                    <span class="text-red-400">security:</span>
                                    <span class="text-green-400">'Enterprise Grade'</span>,
                                </div>
                                <div class="pl-4 flex gap-2">
                                    <span class="text-red-400">delivery:</span>
                                    <span class="text-green-400">'On Time'</span>
                                </div>
                                <div class="text-yellow-300">}</div>
                                <div class="flex gap-2 mt-4">
                                    <span class="text-blue-400">Rampmaster</span>.<span class="text-yellow-300">build</span>(<span class="text-blue-400">project</span>);
                                </div>
                                <div class="mt-2 text-gray-500">// Ready to deploy...</div>
                                <div class="mt-1 animate-pulse text-rm-teal">█</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section (CTA) -->
    <section id="contacto" class="py-24 bg-rm-black text-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#333 1px, transparent 1px); background-size: 30px 30px;"></div>
        <div class="container mx-auto px-4 relative z-10 text-center">
            <h2 class="text-4xl md:text-5xl font-heading font-bold mb-8">¿Listo para solucionar problemas?</h2>
            <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">Hablemos hoy y define el plan que mejor se adapta a tu etapa actual.</p>
            
            <a href="mailto:rmorenp@rampmaster.org" class="inline-flex items-center gap-3 bg-rm-teal text-white font-bold text-xl px-10 py-5 rounded-full hover:bg-white hover:text-rm-teal transition-all hover:scale-105 shadow-2xl shadow-rm-teal/30">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                rmorenp@rampmaster.org
            </a>
        </div>
    </section>
</MainLayout>
